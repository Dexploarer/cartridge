{
	"name": "@cartridge/desktop",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Cartridge desktop host on Electrobun",
	"scripts": {
		"start": "electrobun dev",
		"dev": "electrobun dev --watch",
		"build:canary": "electrobun build --env=canary",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"ui:dev": "vite",
		"ui:build": "vite build",
		"shadcn": "bunx --bun shadcn@latest",
		"css:shadcn-mainview": "tailwindcss -i ./src/styles/shadcn-for-mainview.css -o ./src/mainview/shadcn-tw.css --minify"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.0",
		"@cartridge/runtime": "workspace:*",
		"@cartridge/shared": "workspace:*",
		"@fontsource-variable/geist": "^5.2.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electrobun": "1.16.0",
		"lucide-react": "^1.8.0",
		"motion": "^12.38.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.2.2",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "latest",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"shadcn": "^4.2.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.7.2",
		"vite": "^8.0.8"
	}
}
