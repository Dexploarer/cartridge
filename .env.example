# Cartridge — copy to `.env` and adjust. Bun loads `.env` from the cwd when running `electrobun dev`.

# Public product URLs (override defaults from `packages/shared/src/catalog.ts`)
# Defaults: docs https://docs.cartridge.gg · app https://app.cartridge.gg · cloud https://cloud.cartridge.gg
CARTRIDGE_DOCS_URL=
CARTRIDGE_APP_URL=
CARTRIDGE_CLOUD_URL=
CARTRIDGE_BUG_REPORT_URL=

# Optional: Bearer token for cloud APIs (never commit real secrets)
CARTRIDGE_API_TOKEN=

# Optional: HTTP endpoints that return JSON for the operator UI (see `packages/runtime/src/data-plane-remote.ts`)
# Knowledge: array or `{ "documents": [ ... ] }` with fields docId, title, source, scope, excerpt, tokensApprox, lastIndexedAt, embeddingModel
CARTRIDGE_KNOWLEDGE_API_URL=
# Data plane: array or `{ "stores": [ ... ] }` with storeId, label, kind, status, region, recordsApprox, syncedWithMilady
CARTRIDGE_DATA_PLANE_API_URL=

# --- Intelligence plane (ElizaOS Cloud + external APIs + local inference, Milady-compatible) ---
# ElizaOS Cloud dashboard + API (defaults match shared catalog if unset)
CARTRIDGE_ELIZA_CLOUD_DASHBOARD_URL=
CARTRIDGE_ELIZA_CLOUD_API_BASE_URL=
# API key for Eliza (optional here if you paste session key in the desktop UI instead)
CARTRIDGE_ELIZA_CLOUD_TOKEN=
# Aliases also accepted: ELIZA_CLOUD_API_KEY, ELIZA_CLOUD_TOKEN

# OpenAI-compatible providers
OPENAI_API_KEY=
CARTRIDGE_OPENAI_API_KEY=
CARTRIDGE_OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
CARTRIDGE_ANTHROPIC_API_KEY=
# Extra OpenAI-compatible base (e.g. Groq, Together) — enables Custom row in Intelligence tab
CARTRIDGE_CUSTOM_OPENAI_BASE_URL=

# Local inference
CARTRIDGE_OLLAMA_BASE_URL=
CARTRIDGE_LM_STUDIO_URL=
